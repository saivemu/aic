# Plan E REPLACE mode with earlier visual servo start (7s instead of 9s).
# Gives the classifier 2 extra seconds to close the lateral gap.
AIC_POLICY_PLAN=d
AIC_VISUAL_SERVO_START_S=7.0
AIC_VISUAL_SERVO_Z_MODE=act
AIC_VISUAL_SERVO_ASSIST_MODE=0
AIC_VISUAL_SERVO_CONFIDENCE_MIN=0.0
AIC_VISUAL_SERVO_DIRECTION_SPEED_MPS=0.003
AIC_VISUAL_SERVO_MAX_XY_SPEED_MPS=0.006
AIC_MAX_TRIAL_S=30.0
AIC_FORCE_DESCENT_ENABLED=0
