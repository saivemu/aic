# T1.2 — assist mode + force-feedback descent (conservative defaults)
AIC_POLICY_PLAN=d
AIC_VISUAL_SERVO_START_S=9.0
AIC_VISUAL_SERVO_Z_MODE=act
AIC_VISUAL_SERVO_ASSIST_MODE=1
AIC_VISUAL_SERVO_CONFIDENCE_MIN=0.65
AIC_VISUAL_SERVO_DIRECTION_SPEED_MPS=0.003
AIC_VISUAL_SERVO_MAX_XY_SPEED_MPS=0.006
AIC_MAX_TRIAL_S=30.0

# Force-feedback descent
AIC_FORCE_DESCENT_ENABLED=1
AIC_FORCE_DESCENT_START_S=14.0
AIC_FORCE_DESCENT_BUDGET_S=12.0
# Plan D steady-state has F~20N during the approach window, so contact_delta
# needs headroom above that baseline noise — bump to 4N. Slow the search
# descent rate so steady-state friction doesn't drift the baseline. Widen the
# perturb radius to 4mm to actually explore around the port.
AIC_FORCE_DESCENT_CONTACT_FZ_DELTA_N=4.0
# Plan D's wrench reading sits around 20-21 N during the approach window
# (likely a constant offset, not actual sustained insertion force). Set the
# abort threshold to baseline+8 N so we trip only on a real wall-hit spike.
AIC_FORCE_DESCENT_MAX_FZ_N=28.0
AIC_FORCE_DESCENT_SEARCH_VZ_MPS=-0.0015
AIC_FORCE_DESCENT_INSERT_VZ_MPS=-0.003
AIC_FORCE_DESCENT_PERTURB_RADIUS_M=0.004
AIC_FORCE_DESCENT_PERTURB_PERIOD_S=2.0
AIC_FORCE_DESCENT_COMPLETE_DEPTH_M=0.008
AIC_FORCE_DESCENT_REQUIRE_VS_CONF=1
AIC_FORCE_DESCENT_VS_CONF_MIN=0.55
AIC_FORCE_DESCENT_VS_CONF_TICKS=6
AIC_FORCE_DESCENT_MAX_XY_SPEED_MPS=0.004
