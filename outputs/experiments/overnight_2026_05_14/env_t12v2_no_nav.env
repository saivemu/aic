# T1.2 v2 — fallback: LIFT then straight DESCEND from Plan D's stuck position.
# No classifier navigation. Tests whether reset+lift+force-feedback alone helps.
AIC_POLICY_PLAN=d
AIC_VISUAL_SERVO_START_S=9.0
AIC_VISUAL_SERVO_Z_MODE=act
AIC_VISUAL_SERVO_ASSIST_MODE=0
AIC_VISUAL_SERVO_CONFIDENCE_MIN=0.0
AIC_VISUAL_SERVO_DIRECTION_SPEED_MPS=0.003
AIC_VISUAL_SERVO_MAX_XY_SPEED_MPS=0.006
AIC_MAX_TRIAL_S=30.0

AIC_FORCE_DESCENT_ENABLED=1
AIC_FORCE_DESCENT_START_S=14.0
AIC_FORCE_DESCENT_BUDGET_S=12.0
AIC_FORCE_DESCENT_CONTACT_FZ_DELTA_N=3.5
AIC_FORCE_DESCENT_MAX_FZ_N=28.0
AIC_FORCE_DESCENT_SEARCH_VZ_MPS=-0.003
AIC_FORCE_DESCENT_INSERT_VZ_MPS=-0.005
AIC_FORCE_DESCENT_COMPLETE_DEPTH_M=0.006
AIC_FORCE_DESCENT_REQUIRE_VS_CONF=0

# LIFT 3mm then go straight to DESCEND (skip NAVIGATE entirely by zero
# navigate_max_s and zero hold_ticks → port_found is true immediately).
AIC_FORCE_DESCENT_LIFT_VZ_MPS=0.010
AIC_FORCE_DESCENT_LIFT_DURATION_S=0.3
AIC_FORCE_DESCENT_NAVIGATE_SPEED_MPS=0.0
AIC_FORCE_DESCENT_NAVIGATE_MAX_S=0.1
AIC_FORCE_DESCENT_NAVIGATE_HOLD_TICKS=0
AIC_FORCE_DESCENT_DESCEND_MAX_S=8.0
